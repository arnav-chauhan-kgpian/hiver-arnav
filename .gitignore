# Byte-compiled / optimized / cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# uv / pip
.uv/
pip-log.txt

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Environment / secrets
.env
.env.*
.streamlit/secrets.toml

# Data artifacts (keep the code, not the generated data)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Pipeline outputs
outputs/*
!outputs/.gitkeep

# Model / index caches
*.faiss
*.index
.cache/

# IDE / editor
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/
